{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start server",
      "program": "${workspaceFolder}/server.js",
      "restart": true,
      "env": {
        "PORT": "3000"
      },
      "serverReadyAction": {
        "pattern": "Server running at http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ]
}
